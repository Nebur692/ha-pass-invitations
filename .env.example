# Copy this file to .env and fill in your values. Never commit .env.

# Admin dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Home Assistant connection
# Base URL of your HA instance (no trailing slash)
HA_BASE_URL=http://homeassistant.local:8123
# Long-lived access token: HA → Profile → Security → Create Token
HA_TOKEN=your_long_lived_token_here

# SQLite database path (inside the container, mapped via volume)
DB_PATH=/data/db.sqlite

# Server port
PORT=5880

# Branding shown to guests
APP_NAME=Home Access
CONTACT_MESSAGE=Please request a new link from the person who shared this one.

# Retention period for guest access logs (days). Older rows are cleaned up.
ACCESS_LOG_RETENTION_DAYS=90

# Timezone used to evaluate recurring weekly access windows (IANA name).
# Only matters if you use the "recurrence" schedule on a token.
TIMEZONE=Europe/Madrid

# CIDRs considered "on the home network". When set, guests can only trigger
# access-type entities (locks, covers, button/input_button) while their
# request comes from one of these ranges — lights and other domains are
# unaffected. JSON array of strings. Leave unset/empty for no restriction.
# LOCAL_NETWORK_CIDRS=["192.168.0.0/16"]
